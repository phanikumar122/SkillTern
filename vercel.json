{
  "version": 2,
  "builds": [
    {
      "src": "smart-internship-checker/backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "smart-internship-checker/frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "smart-internship-checker/backend/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "smart-internship-checker/frontend/$1"
    }
  ]
}
